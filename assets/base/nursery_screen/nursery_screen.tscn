[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://assets/base/nursery_screen/nursery_screen.gd" id="1_screen"]
[ext_resource type="Theme" path="res://assets/themes/default.tres" id="2_theme"]

[node name="NurseryScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_screen")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"ScreenMargin"

[node name="RootVBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_type_variation = &"SectionVBox"

[node name="Header" type="Label" parent="Margin/RootVBox"]
layout_mode = 2
theme_type_variation = &"PageTitleLabel"
text = "Nursery — Grow Units"

[node name="Subtitle" type="Label" parent="Margin/RootVBox"]
layout_mode = 2
theme_type_variation = &"PageSubtitleLabel"
text = "Click an empty plot or drag a spore onto it. Click a ready plot to harvest to the bench."

[node name="StockPanel" type="PanelContainer" parent="Margin/RootVBox"]
